# ==========================================================================
# agentic-testing-panel — variables de entorno
# Copiar este archivo como .env.local y completar los valores.
# ==========================================================================

# --- Supabase -------------------------------------------------------------
# Project Settings > API en el dashboard de Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: NUNCA exponer al cliente. Solo se usa en API routes / worker.
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (motor principal vía Claude Agent SDK) ---------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_ORCHESTRATOR=claude-sonnet-4-6
ANTHROPIC_MODEL_SUBAGENT=claude-haiku-4-5
ANTHROPIC_MODEL_EVALUATOR=claude-haiku-4-5

# --- OpenRouter (fallback) — DIFERIDO A FASE 2 ----------------------------
# El fallback Anthropic -> OpenRouter no se implementa en fase 1.
# Estas variables quedan documentadas para cuando se agregue.
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL_ORCHESTRATOR=anthropic/claude-sonnet-4
# OPENROUTER_MODEL_SUBAGENT=anthropic/claude-haiku-4
# OPENROUTER_MODEL_EVALUATOR=anthropic/claude-haiku-4

# --- Configuracion del agente ---------------------------------------------
AGENT_MAX_ITERATIONS=3
AGENT_TIMEOUT_MS=60000

# --- Webhooks / jobs -------------------------------------------------------
# CRON_SECRET protege el endpoint /api/jobs/process (header x-cron-secret).
CRON_SECRET=
# WEBHOOK_SIGNING_SECRET firma (HMAC) los webhooks salientes.
WEBHOOK_SIGNING_SECRET=

# --- App -------------------------------------------------------------------
# URL base de la app (usada por el auto-trigger del worker en local).
# En produccion: la URL de Vercel. En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
